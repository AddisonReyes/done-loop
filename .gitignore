# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
coverage/

# next.js
.next/
/out/

# production
/build
build/
dist/

# misc
.DS_Store
*.pem
*.keystore
!mobile/android/app/debug.keystore

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
