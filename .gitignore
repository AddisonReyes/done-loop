# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Expo / React Native local artifacts
.expo/
mobile/.expo/
android/build/
android/app/build/
mobile/android/build/
mobile/android/app/build/
ios/build/
mobile/ios/build/
*.jks
